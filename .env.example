# Supabase (obrigatorio em producao)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternativa ao anon key (dashboard Supabase "publishable")
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Somente servidor — upload admin e operacoes privilegiadas
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Blob — imagens de skins (store ligado ao projeto Vercel)
BLOB_READ_WRITE_TOKEN=

# URL publica do site (redirects Supabase Auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Legado — nao usar apos migracao Supabase Auth (0524)
# DRBLACK_SESSION_SECRET=
